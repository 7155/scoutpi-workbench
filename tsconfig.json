{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    ".pi/extensions/**/*.ts",
    "packages/earth-backend-sdk/**/*.ts",
    "packages/earth-investigation-core/**/*.ts",
    "packages/earth-workspace/**/*.ts",
    "packages/earth-workspace-server/**/*.ts",
    "packages/earth-workflow-compiler/**/*.ts",
    "packages/pi-ecosystem/**/*.ts",
    "packages/runtime-context/**/*.ts",
    "packages/runtime-checkpoint/**/*.ts",
    "packages/runtime-evidence/**/*.ts",
    "packages/runtime-governance/**/*.ts",
    "packages/runtime-observability/**/*.ts",
    "packages/runtime-telemetry/**/*.ts",
    "harness/earth/**/*.ts",
    "harness/pi/**/*.ts",
    "tests/*.test.ts"
  ]
}
