{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    ".pi/extensions/scoutpi-earth/**/*.ts",
    "packages/earth-investigation-core/**/*.ts",
    "packages/earth-workspace/**/*.ts",
    "packages/earth-workspace-server/**/*.ts",
    "packages/pi-ecosystem/**/*.ts",
    "harness/earth/**/*.ts",
    "tests/*.test.ts"
  ]
}
