# Browser-visible Cesium ion token. Use an assets:read-only token restricted to your deployment origins.
VITE_CESIUM_ION_TOKEN=

# Optional Cesium ion scene content: osm or none.
VITE_CESIUM_ION_BUILDINGS=osm

# Optional custom Cesium terrain endpoint. When absent, ion terrain is used if a token exists,
# then ArcGIS WorldElevation3D, then the ellipsoid fallback.
VITE_CESIUM_TERRAIN_URL=
