{
  "name": "scoutpi-workbench",
  "version": "0.2.0",
  "type": "module",
  "description": "Pi-native Earth observation investigation runtime and evidence workbench.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/7155/scoutpi-workbench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7155/scoutpi-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/7155/scoutpi-workbench/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "earth-observation",
    "google-earth-engine",
    "geospatial"
  ],
  "files": [
    ".pi/extensions",
    ".pi/skills",
    "examples",
    "packages/earth-backend-sdk",
    "packages/earth-investigation-core",
    "packages/earth-workflow-compiler",
    "packages/earth-workspace",
    "packages/pi-ecosystem",
    "packages/runtime-checkpoint",
    "packages/runtime-context",
    "packages/runtime-evidence",
    "packages/runtime-governance",
    "packages/runtime-observability",
    "packages/runtime-telemetry",
    "packages/runtime-trigger",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.6"
  },
  "pi": {
    "extensions": [
      "./.pi/extensions/scoutpi-context/index.ts",
      "./.pi/extensions/scoutpi-evidence/index.ts",
      "./.pi/extensions/scoutpi-triggers/index.ts",
      "./.pi/extensions/scoutpi-governance/index.ts",
      "./.pi/extensions/scoutpi-observability/index.ts",
      "./.pi/extensions/scoutpi-checkpoint/index.ts",
      "./.pi/extensions/scoutpi-earth/index.ts"
    ],
    "skills": [
      "./.pi/skills/scoutpi-earth-investigation"
    ],
    "image": "https://raw.githubusercontent.com/7155/scoutpi-workbench/main/docs/assets/workbench-live-gee.png"
  },
  "scripts": {
    "earth:server": "node --experimental-strip-types packages/earth-workspace-server/src/index.ts",
    "mcp:stdio": "node --experimental-strip-types packages/scoutpi-mcp-server/src/index.ts",
    "examples:seed": "node --experimental-strip-types scripts/seedExampleAdapters.ts",
    "harness:earth": "node --experimental-strip-types harness/earth/runEarthWorkspaceDemo.ts",
    "harness:guangxi-flood": "node --experimental-strip-types harness/earth/runGuangxiFloodVegetationDemo.ts",
    "harness:guangxi-flood-live": "node --experimental-strip-types harness/earth/runGuangxiFloodVegetationDemo.ts --live",
    "harness:mcp": "node --experimental-strip-types harness/mcp/runMcpSmoke.ts",
    "harness:context-provider": "node --experimental-strip-types harness/context/runImeProviderBenchmark.ts",
    "harness:pi": "node --experimental-strip-types harness/pi/runPiRpcHarness.ts",
    "harness:pi-rpc": "node --experimental-strip-types harness/pi/runPiRpcHarness.ts --rpc-smoke",
    "harness:pi-live": "node --experimental-strip-types harness/pi/runPiRpcHarness.ts --live",
    "harness:pi-live-all": "node --experimental-strip-types harness/pi/runPiRpcHarness.ts --live --all",
    "harness:interview": "node --experimental-strip-types harness/interview/runInterviewBenchmark.ts",
    "harness:interview-demo": "node --experimental-strip-types harness/interview/runEndToEndDemo.ts",
    "harness:recovery": "node --experimental-strip-types harness/recovery/runDurableRecoveryDemo.ts",
    "web:dev": "pnpm --filter @scoutpi/earth-workbench dev",
    "web:build": "pnpm --filter @scoutpi/earth-workbench build",
    "workbench:dev": "node scripts/runEarthWorkbench.mjs",
    "package:verify": "node scripts/verifyPiPackage.mjs",
    "prepublishOnly": "pnpm check",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "python:check": "uv run python -m py_compile packages/earth-workspace/python/worker.py packages/runtime-context/python/ime_core_context_provider.py",
    "check": "pnpm typecheck && pnpm test && pnpm python:check && pnpm harness:earth && pnpm harness:mcp && pnpm harness:interview && pnpm harness:interview-demo && pnpm harness:recovery && pnpm package:verify && pnpm web:build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "typebox": "1.1.38",
    "typescript": "^5.9.3"
  }
}
